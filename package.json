{
  "name": "change-management-tool",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w @cmt/server\" \"npm run dev -w @cmt/client\"",
    "build": "npm run build -w @cmt/client && npm run typecheck -ws --if-present",
    "test": "npm run test -ws --if-present",
    "typecheck": "npm run typecheck -ws --if-present",
    "lint": "eslint \"packages/*/src/**/*.{ts,tsx}\" \"packages/server/test/**/*.ts\"",
    "check": "npm run typecheck && npm run lint && npm run coverage",
    "start": "npm run start -w @cmt/server",
    "backup": "npm run backup -w @cmt/server",
    "coverage": "npm run coverage -ws --if-present",
    "e2e": "playwright test -c e2e/playwright.config.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^3.2.7",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.64.0"
  }
}
